  "keyFeatures": [
    "Declarative asset-based pipeline orchestration",
    "Built-in observability and data lineage tracking",
    "Comprehensive testing framework for data pipelines",
    "Rich library of integrations with modern data stack tools",
    "Flexible deployment options (local, Docker, Kubernetes, cloud)",
    "Declarative automation with schedules and sensors",
    "Asset checks for data quality validation",
    "Partitioned assets for incremental processing",
    "Type-safe configuration with Python",
    "GraphQL API and web-based UI"
  ],
  "publicApiSurface": [
    "@asset - Define data assets",
    "@multi_asset - Define multiple related assets",
    "@op - Define computation units",
    "@job - Define executable workflows",
    "@graph - Compose ops into reusable graphs",
    "@schedule - Define time-based automation",
    "@sensor - Define event-based automation",
    "@asset_check - Define data quality checks",
    "@resource - Define reusable resources",
    "Definitions - Container for all definitions",
    "ConfigurableResource - Type-safe resource configuration",
    "AssetSelection - Select assets for execution",
    "DailyPartitionsDefinition - Daily time partitions",
    "HourlyPartitionsDefinition - Hourly time partitions",
    "StaticPartitionsDefinition - Static partition keys",
    "DynamicPartitionsDefinition - Runtime partition keys",
    "materialize - Execute asset materialization",
    "define_asset_job - Create jobs from assets",
    "AssetSpec - Declarative asset specification",
    "AssetDep - Declare asset dependencies",
    "AssetIn - Configure asset inputs",
    "AssetOut - Configure asset outputs",
    "OpExecutionContext - Runtime context for ops",
    "AssetExecutionContext - Runtime context for assets",
    "RunRequest - Request pipeline execution",
    "SkipReason - Skip execution with reason",
    "BackfillPolicy - Configure backfill behavior",
    "AutoMaterializePolicy - Automatic asset refresh",
    "FreshnessPolicy - Define data freshness requirements",
    "RetryPolicy - Configure retry behavior",
    "dagster CLI - Command-line interface",
    "dagster-daemon - Background process runner",
    "dg CLI - Code generation and scaffolding"
  ]
}
